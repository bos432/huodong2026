# Copy this file to deploy/.env.production and replace every change-me value before production deployment.

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=activity_registration
MYSQL_USER=activity
MYSQL_PASSWORD=change-me-db-password

NODE_ENV=production
APP_VERSION=0.1.0
BUILD_COMMIT=change-me-git-commit
BUILD_TIME=change-me-build-time
API_PORT=3000
INSTALLER_ENABLED=false
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=activity
DB_PASSWORD=change-me-db-password
DB_DATABASE=activity_registration
DB_SYNCHRONIZE=false

JWT_SECRET=change-me-long-random-secret
CORS_ORIGIN=https://h5.example.com,https://admin.example.com
TRUST_PROXY=true
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
VALIDATION_FORBID_NON_WHITELISTED=true
ACCESS_LOG_ENABLED=true
ACCESS_LOG_SKIP_HEALTH=true

PUBLIC_H5_ORIGIN=https://h5.example.com
PUBLIC_ADMIN_ORIGIN=https://admin.example.com
PUBLIC_API_ORIGIN=https://api.example.com
UPLOAD_DIR=uploads

# H5 public login. Production must use sms mode and a strong signing secret.
H5_AUTH_MODE=sms
H5_AUTH_SECRET=change-me-h5-auth-secret-at-least-32-chars
H5_CODE_EXPIRE_MINUTES=10
H5_CODE_COOLDOWN_SECONDS=60
H5_CODE_PHONE_HOURLY_LIMIT=6
H5_CODE_PHONE_DAILY_LIMIT=20
H5_CODE_IP_HOURLY_LIMIT=60
# Local development only; ignored when H5_AUTH_MODE=sms.
H5_DEV_VERIFICATION_CODE=123456

# Admin login protection. Failed attempts are audited and rate-limited by username + IP.
ADMIN_LOGIN_WINDOW_MINUTES=10
ADMIN_LOGIN_MAX_FAILURES=5
ADMIN_LOGIN_LOCK_MINUTES=10

# Sandbox payment callback signatures. Replace before staging tests, and use official
# WeChat Pay / Alipay certificates and SDK verification before real production payment.
PAYMENT_SANDBOX_ENABLED=false
PAYMENT_SANDBOX_SECRET=change-me-payment-sandbox-secret
WECHAT_PAY_SANDBOX_SECRET=change-me-wechat-sandbox-secret
ALIPAY_PAY_SANDBOX_SECRET=change-me-alipay-sandbox-secret

# Real payment launch target: WeChat first, Alipay disabled. Keep rollout flags
# false until real staging evidence has been filled and validated.
REAL_PAYMENT_ENABLED=false
REAL_PAYMENT_SDK_IMPLEMENTED=false
REAL_PAYMENT_CALLBACK_VERIFICATION_IMPLEMENTED=false
REAL_REFUND_QUERY_IMPLEMENTED=false
REAL_PAYMENT_STATEMENT_FETCH_IMPLEMENTED=false
AGENT_REAL_TRANSFER_IMPLEMENTED=false
MALL_REAL_WECHAT_PAYMENT_IMPLEMENTED=false
MALL_MERCHANT_DIRECT_PAYMENT_IMPLEMENTED=false
REAL_PAYMENT_PREFLIGHT_PASSED=false
REAL_PAYMENT_PREFLIGHT_RESULT_FILE=deploy/real-payment-smoke-result.json
REAL_PAYMENT_PREFLIGHT_MAX_AGE_HOURS=168

# Multi-tenant isolation placeholders. Keep disabled until tenant schema,
# access filters, public routing and preflight isolation tests are complete.
MULTI_TENANT_ENABLED=false
MULTI_TENANT_SCHEMA_IMPLEMENTED=false
MULTI_TENANT_ACCESS_FILTER_IMPLEMENTED=false
MULTI_TENANT_PUBLIC_BOUNDARY_IMPLEMENTED=false
MULTI_TENANT_PREFLIGHT_PASSED=false
MULTI_TENANT_PREFLIGHT_RESULT_FILE=deploy/tenant-smoke-result.json
MULTI_TENANT_PREFLIGHT_MAX_AGE_HOURS=168

# Multi-merchant mall rollout. Keep disabled until smoke:mall-multi-merchant
# has passed on the target production API and the result file is retained.
MALL_MULTI_MERCHANT_ENABLED=false
MALL_MULTI_MERCHANT_PREFLIGHT_PASSED=false
MALL_MULTI_MERCHANT_SMOKE_RESULT_FILE=deploy/mall-multi-merchant-smoke-result.json
MALL_MULTI_MERCHANT_SMOKE_MAX_AGE_HOURS=168

WECHAT_PAY_ENABLED=false
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PLATFORM_CERT_PATH=
WECHAT_PAY_NOTIFY_URL=
WECHAT_TRANSFER_APP_ID=
WECHAT_TRANSFER_SCENE_ID=
WECHAT_TRANSFER_REMARK=Agent settlement payout
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_CERT_PATH=
ALIPAY_ROOT_CERT_PATH=
ALIPAY_NOTIFY_URL=

# H5_AUTH_MODE=sms requires a real SMS provider before production traffic is enabled.
# SMS provider credentials are preferably maintained in the admin System Settings page;
# these env fields are kept as initial bootstrap/fallback values.
SMS_PROVIDER_ENABLED=true
SMS_PROVIDER=tencent-cloud-sms
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_ID=
SMS_SDK_APP_ID=
EMAIL_PROVIDER_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
WECHAT_MESSAGE_PROVIDER_ENABLED=false
WECHAT_MESSAGE_PROVIDER=wechat-subscribe-message
WECHAT_LOGIN_REAL_ENABLED=true
WECHAT_APP_ID=
WECHAT_APP_SECRET=
NOTIFICATION_FORCE_FAIL=false
NOTIFICATION_SCHEDULE_WORKER_ENABLED=false
NOTIFICATION_SCHEDULE_WORKER_INTERVAL_SECONDS=300

# Offline payment order expiry. Pending offline-payment orders are closed after this window.
OFFLINE_PAYMENT_EXPIRE_MINUTES=1440
# Recommended true in production so unpaid offline orders eventually release seats.
ORDER_CLOSE_WORKER_ENABLED=true
ORDER_CLOSE_WORKER_INTERVAL_SECONDS=300

# Database backup. Keep BACKUP_DIR on a persistent disk or sync it to object storage.
BACKUP_DIR=backups/mysql
BACKUP_RETENTION_DAYS=30
BACKUP_USE_DOCKER=true
MYSQL_CONTAINER=activity-mysql
