{
  "name": "@activity/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "migration:show": "npm run build && typeorm -d dist/data-source.js migration:show",
    "migration:run": "npm run build && typeorm -d dist/data-source.js migration:run",
    "migration:revert": "npm run build && typeorm -d dist/data-source.js migration:revert",
    "migration:generate": "typeorm-ts-node-commonjs -d src/data-source.ts migration:generate src/migrations/AutoMigration",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "16.4.5",
    "exceljs": "^4.4.0",
    "miniprogram-ci": "^2.1.31",
    "mysql2": "^3.11.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tencentcloud-sdk-nodejs": "^4.1.260",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
