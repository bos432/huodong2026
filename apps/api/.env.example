NODE_ENV=development
API_PORT=3000

# Docker Compose mysql defaults use 127.0.0.1:3306 from the host.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=activity
DB_PASSWORD=activitypass
DB_DATABASE=activity_registration

JWT_SECRET=dev-secret-change-me
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:8080

# Sandbox payment signatures for local WeChat/Alipay callback verification.
# Real merchant credentials and official provider signature verification are configured later.
PAYMENT_SANDBOX_SECRET=dev-payment-secret
WECHAT_PAY_SANDBOX_SECRET=
ALIPAY_PAY_SANDBOX_SECRET=

# Notification providers. Local development uses mock providers by default.
SMS_PROVIDER_ENABLED=mock
SMS_PROVIDER=mock-sms
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
EMAIL_PROVIDER_ENABLED=mock
EMAIL_PROVIDER=mock-email
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
WECHAT_MESSAGE_PROVIDER_ENABLED=mock
WECHAT_MESSAGE_PROVIDER=mock-wechat
WECHAT_APP_ID=
WECHAT_APP_SECRET=
NOTIFICATION_FORCE_FAIL=false
NOTIFICATION_SCHEDULE_WORKER_ENABLED=false
NOTIFICATION_SCHEDULE_WORKER_INTERVAL_SECONDS=300
